{
  "$schema": "https://typedoc.org/schema.json",

  "compilerOptions": {
    "skipLibCheck": true
  },

  "entryPoints": [
    "./src/color-mode/index.ts",
    "./src/discriminator/index.ts",
    "./src/palette-color/index.ts",
    "./src/rgb/index.ts",
    "./src/string/index.ts"
  ],

  "out": "./_doc",

  "includeVersion": true,

  "navigationLinks": {
    "TypeScript Color Utilities": "https://blwatkins.github.io/typescript-color-utils/",
    "Brittni Watkins": "https://blwatkins.github.io/"
  },

  "navigation": {
    "includeCategories": true,
    "includeGroups": true,
    "includeFolders": true
  },

  "visibilityFilters": {
    "private": true,
    "protected": true,
    "inherited": true,
    "external": true,
    "@alpha": true,
    "@beta": true,
    "@deprecated": true
  },

  "sort": ["kind", "visibility", "static-first", "alphabetical", "enum-value-ascending"],

  "validation": {
    "notExported": true,
    "invalidLink": true,
    "notDocumented": true
  },

  "externalSymbolLinkMappings": {
    "@blwatkins/utils": { "Discriminated": "#" }
  },

  "intentionallyNotDocumented": [],

  "treatWarningsAsErrors": true,

  "customFooterHtml": "<br/>Copyright &copy; 2024-2026 Brittni Watkins."
}
